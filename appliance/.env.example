# qmt-mcp runtime config — copy to `.env` and fill in. (`.env` is git-ignored.)
#   cp .env.example .env
# Then: docker compose up -d   (run scripts/harden-check.sh before exposing.)

# --- required ---

# Bearer token for the MCP endpoint. Generate a strong random one:
#   openssl rand -hex 32
QMT_MCP_TOKEN=

# Path on the host to your broker pack (extracted QMT terminal + matching xtquant
# + broker.yaml). Built with scripts/make-broker-pack.sh. Must be on real disk.
BROKER_PACK=/path/to/brokers/<broker-id>/pack

# --- optional (defaults shown) ---

# Instance name → container is named qmt-<INSTANCE>; use distinct names to run
# several brokers on one host.
INSTANCE=default

# Host ports (host:container). RDP=3389, MCP=8765 inside the container.
RDP_PORT=13389
MCP_PORT=18765

# RDP desktop password for user `wineuser`. CHANGE THIS — `qmt` is a dev default.
QMT_RDP_PASSWORD=qmt

# --- optional: PostgreSQL persistence (012) ---
# Leave empty to keep file/JSONL defaults (no DB). Point at any PostgreSQL, or use
# the bundled `db` service: run `docker compose --profile db up -d` and set:
#   QMT_DB_URL=postgresql://qmt:qmt@db:5432/qmt
QMT_DB_URL=
# Credentials for the bundled `db` service (only used with --profile db):
QMT_DB_USER=qmt
QMT_DB_PASSWORD=qmt
QMT_DB_NAME=qmt

# --- optional: read-only account queries (004) ---
# Enable xttrade read-only account-query tools (asset/positions/orders/trades/...).
# Requires broker "programmatic trading / external Python API" permission
# (m_nPythonConnectNet). Without it, tools return not_authorized (graceful).
# QMT_ENABLE_XTTRADE_QUERY=1
# Comma-separated account IDs allowed for xttrade queries (server-side allowlist;
# the agent cannot widen it).
# QMT_TRADE_ACCOUNTS=

# --- multi-broker tip ---
# Copy this file per instance (e.g. broker-a.env) with distinct INSTANCE / ports /
# QMT_MCP_TOKEN / BROKER_PACK, then:
#   docker compose --env-file broker-a.env -p qmt-a up -d
